{
  "name": "@hasna/netwatch",
  "version": "0.1.0",
  "description": "Live network traffic monitor — track data usage per interface with process breakdown",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "netwatch": "src/index.ts"
  },
  "files": [
    "src",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "postinstall": "mkdir -p $HOME/.hasna/netwatch 2>/dev/null || true"
  },
  "keywords": [
    "network",
    "monitor",
    "traffic",
    "bandwidth",
    "cli",
    "terminal"
  ],
  "author": "Andrei Hasna <andrei@hasna.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/netwatch.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hasna/cloud": "^0.1.24"
  }
}
